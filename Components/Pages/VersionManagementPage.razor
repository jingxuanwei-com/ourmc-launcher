@using ourmclauncher.Models

<div class="page-modal hub-page version-management-page">
    <div class="modal-header hub-header">
        <div class="panel-title-bar">
            <span class="panel-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
                    <polyline points="3.27,6.96 12,12.01 20.73,6.96"/>
                    <line x1="12" y1="22.08" x2="12" y2="12"/>
                </svg>
            </span>
            <div>
                <h2>版本管理</h2>
                <p class="hub-subtitle">版本、实例、资源与启动配置</p>
            </div>
        </div>
        @if (Versions.Count > 0)
        {
            <label class="hub-version-selector">
                <span>当前版本</span>
                <select value="@EffectiveVersionId" @onchange="HandleVersionChanged">
                    @foreach (var version in Versions)
                    {
                        <option value="@version.Name">@version.Name</option>
                    }
                </select>
            </label>
        }
    </div>

    <div class="hub-tabs hub-tabs-scroll" role="tablist" aria-label="版本管理功能">
        <button class="hub-tab @IsActive("versions")" @onclick="ShowVersions">已安装版本</button>
        <button class="hub-tab @IsActive("instances")" @onclick="ShowInstances">实例</button>
        <button class="hub-tab @IsActive("resources")" @onclick="ShowResources">资源</button>
        <button class="hub-tab @IsActive("params")" @onclick="ShowLaunchParams">启动参数</button>
        <button class="hub-tab @IsActive("optimization")" @onclick="ShowOptimization">启动优化</button>
        <button class="hub-tab @IsActive("diagnostics")" @onclick="ShowDiagnostics">日志诊断</button>
    </div>

    <div class="hub-content">
        @switch (_activeSection)
        {
            case "instances":
                <InstancesPage AvailableVersions="Versions" OnClose="ShowVersions" OnInstanceLaunch="OnInstanceLaunch" />
                break;
            case "resources":
                <ResourcesPage CurrentVersionId="EffectiveVersionId" OnClose="ShowVersions" />
                break;
            case "params":
                <LaunchParamsPage OnClose="ShowVersions" OnSettingsChanged="OnLaunchSettingsChanged" />
                break;
            case "optimization":
                <LaunchOptimizationPage OnClose="ShowVersions" OnSettingsChanged="OnLaunchSettingsChanged" />
                break;
            case "diagnostics":
                @if (_diagnosticTool == "ai")
                {
                    <AIAnalysisPage OnClose="ShowDiagnostics" />
                }
                else if (_diagnosticTool == "crash")
                {
                    <CrashReportPage OnClose="ShowDiagnostics" />
                }
                else
                {
                    <div class="diagnostic-launcher">
                        <button class="diagnostic-option" @onclick="OpenCrashReports">
                            <span class="diagnostic-option-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"/>
                                    <line x1="15" y1="9" x2="9" y2="15"/>
                                    <line x1="9" y1="9" x2="15" y2="15"/>
                                </svg>
                            </span>
                            <span><strong>崩溃报告</strong><small>查看、整理和定位游戏崩溃日志</small></span>
                        </button>
                        <button class="diagnostic-option" @onclick="OpenAiAnalysis">
                            <span class="diagnostic-option-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                                    <path d="M2 17l10 5 10-5"/>
                                    <path d="M2 12l10 5 10-5"/>
                                </svg>
                            </span>
                            <span><strong>AI 日志分析</strong><small>使用已配置的 AI 服务分析错误日志</small></span>
                        </button>
                    </div>
                }
                break;
            default:
                <VersionsPage
                    Versions="Versions"
                    IsLoading="IsLoading"
                    OnRefresh="OnRefresh"
                    OnLaunch="OnLaunch"
                    OnGoToDownload="OnGoToDownload" />
                break;
        }
    </div>
</div>

@code {
    [Parameter] public List<GameVersion> Versions { get; set; } = new();
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string SelectedVersionId { get; set; } = "";
    [Parameter] public EventCallback<string> SelectedVersionIdChanged { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public EventCallback<string> OnLaunch { get; set; }
    [Parameter] public EventCallback OnGoToDownload { get; set; }
    [Parameter] public EventCallback<string> OnInstanceLaunch { get; set; }
    [Parameter] public EventCallback OnLaunchSettingsChanged { get; set; }

    private string _activeSection = "versions";
    private string? _diagnosticTool;

    private string EffectiveVersionId =>
        Versions.Any(version => version.Name == SelectedVersionId)
            ? SelectedVersionId
            : Versions.FirstOrDefault()?.Name ?? "";

    private string IsActive(string section) => _activeSection == section ? "active" : "";

    private void SelectSection(string section)
    {
        _activeSection = section;
        _diagnosticTool = null;
    }

    private void ShowVersions()
    {
        SelectSection("versions");
    }

    private void ShowInstances() => SelectSection("instances");

    private void ShowResources() => SelectSection("resources");

    private void ShowLaunchParams() => SelectSection("params");

    private void ShowOptimization() => SelectSection("optimization");

    private void ShowDiagnostics()
    {
        _activeSection = "diagnostics";
        _diagnosticTool = null;
    }

    private void OpenDiagnostic(string tool)
    {
        _diagnosticTool = tool;
    }

    private void OpenCrashReports() => OpenDiagnostic("crash");

    private void OpenAiAnalysis() => OpenDiagnostic("ai");

    private async Task HandleVersionChanged(ChangeEventArgs args)
    {
        var versionId = args.Value?.ToString() ?? "";
        await SelectedVersionIdChanged.InvokeAsync(versionId);
    }
}
