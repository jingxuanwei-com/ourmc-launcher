@* 版本管理页面组件 *@
@using ourmclauncher.Models

<div class="page-modal page-version @(IsClosing ? "closing" : "")">
    <div class="modal-header">
        <h2>游戏版本</h2>
        <button class="btn-close-modal" @onclick="OnClose">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>
    <div class="modal-body">
        <div class="version-header">
            <button class="btn-refresh" @onclick="OnRefresh">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="23,4 23,10 17,10"/>
                    <path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/>
                </svg>
                刷新
            </button>
        </div>
        <div class="version-list">
            @if (IsLoading)
            {
                <p class="loading">加载版本列表...</p>
            }
            else if (Versions.Count == 0)
            {
                <p class="empty-text">暂无已安装的版本</p>
                <button class="btn-primary" @onclick="OnGoToDownload">去下载</button>
            }
            else
            {
                @foreach (var version in Versions)
                {
                    <div class="version-item">
                        <div class="version-icon">📦</div>
                        <div class="version-info">
                            <div class="version-name">@version.Name</div>
                            <div class="version-type">@version.Type</div>
                        </div>
                        <button class="btn-play" @onclick="() => OnLaunch.InvokeAsync(version.Name)">启动</button>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public List<GameVersion> Versions { get; set; } = new();
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public bool IsClosing { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public EventCallback<string> OnLaunch { get; set; }
    [Parameter] public EventCallback OnGoToDownload { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
}
