@using ourmclauncher.Models

<div class="home-page">
    <div class="sky-background"></div>
    <div class="center-logo">
        <h1 class="mc-font">ourmc-launcher</h1>
    </div>
    <div class="bottom-bar home-launch-bar">
        <div class="pill large home-launch-pill">
            <div class="large-inner">
                <div class="home-version-summary">
                    <span class="home-version-label">当前版本</span>
                    <span class="home-version-name">@GetSelectedVersionLabel()</span>
                </div>
                <div class="bar-separator"></div>
                <button class="rocket-btn" @onclick="ShowVersionPicker" title="选择并启动游戏">
                    <span class="rocket-icon">
                        <img src="star.png" style="width:16px;height:16px;filter:brightness(0) invert(1);" alt="" />
                    </span>
                    <span class="rocket-text">启动游戏</span>
                </button>
            </div>
        </div>
    </div>

    @if (_showVersionPicker)
    {
        <div class="version-picker-overlay" @onclick="CloseVersionPicker">
            <div class="version-picker-modal" @onclick:stopPropagation="true">
                <div class="picker-header">
                    <h3>选择版本</h3>
                    <button class="picker-close-btn" @onclick="CloseVersionPicker" title="关闭">&times;</button>
                </div>
                <div class="picker-body">
                    @if (Versions.Count == 0)
                    {
                        <div class="picker-empty">
                            <p>还没有安装游戏版本</p>
                            <button class="btn-primary btn-sm" @onclick="GoToDownload">前往下载</button>
                        </div>
                    }
                    else
                    {
                        <div class="picker-list">
                            @foreach (var version in Versions)
                            {
                                <button class="picker-item" @onclick="() => SelectAndLaunch(version.Name)">
                                    <span class="picker-item-name">@version.Name</span>
                                    <span class="picker-item-type">@(string.IsNullOrEmpty(version.Type) ? "原版" : version.Type)</span>
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public List<GameVersion> Versions { get; set; } = new();
    [Parameter] public string SelectedVersionId { get; set; } = "";
    [Parameter] public EventCallback<string> OnLaunchVersion { get; set; }
    [Parameter] public EventCallback OnGoToDownload { get; set; }

    private bool _showVersionPicker;

    private string GetSelectedVersionLabel()
    {
        if (!string.IsNullOrWhiteSpace(SelectedVersionId) && Versions.Any(v => v.Name == SelectedVersionId))
        {
            return SelectedVersionId;
        }

        return Versions.FirstOrDefault()?.Name ?? "未安装";
    }

    private void ShowVersionPicker()
    {
        _showVersionPicker = true;
    }

    private void CloseVersionPicker()
    {
        _showVersionPicker = false;
    }

    private async Task SelectAndLaunch(string versionName)
    {
        _showVersionPicker = false;
        await OnLaunchVersion.InvokeAsync(versionName);
    }

    private async Task GoToDownload()
    {
        _showVersionPicker = false;
        await OnGoToDownload.InvokeAsync();
    }
}
