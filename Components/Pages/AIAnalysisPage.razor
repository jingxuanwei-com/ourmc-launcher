@code {
    [Parameter] public EventCallback OnClose { get; set; }

    private string logContent = "";
    private string additionalInfo = "";
    private AIService.AIAnalysisResult? AnalysisResult;
    private string CurrentErrorMessage = "";
    private bool IsAnalyzing = false;

    // 欢迎屏幕
    private bool ShowWelcomeScreen = false;
    private bool ShowConfigScreen = false;
    private string tempApiKey = "";
    private AIService.AIProvider tempProvider = AIService.AIProvider.OpenAI;

    protected override void OnInitialized()
    {
        ShowWelcomeScreen = AppState.ShowAIWelcome;
    }

    private void OpenConfigScreen()
    {
        ShowConfigScreen = true;
        tempApiKey = AppState.AIApiKey;
        tempProvider = AIService.GetConfiguredProvider();
        StateHasChanged();
    }

    private void HideConfigScreen()
    {
        ShowConfigScreen = false;
        tempApiKey = "";
        StateHasChanged();
    }

    private void SkipWelcome()
    {
        ShowWelcomeScreen = false;
        AppState.ShowAIWelcome = false;
        SettingsService.SetShowAIWelcome(false);
        StateHasChanged();
    }

    private async Task SaveApiKey()
    {
        if (string.IsNullOrEmpty(tempApiKey))
            return;

        if (!AIService.ValidateApiKey(tempApiKey, tempProvider))
        {
            CurrentErrorMessage = "API Key格式无效，请检查后重试";
            StateHasChanged();
            return;
        }

        AppState.AIApiKey = tempApiKey;
        SettingsService.SetAIApiKey(tempApiKey);
        SettingsService.SetAIProvider(tempProvider.ToString());
        AppState.ShowAIWelcome = false;
        SettingsService.SetShowAIWelcome(false);

        await NotificationService.Success("API Key已保存", 2000);
        HideConfigScreen();
        ShowWelcomeScreen = false;
    }

    private async Task AnalyzeLog()
    {
        if (string.IsNullOrEmpty(logContent))
            return;

        IsAnalyzing = true;
        CurrentErrorMessage = "";
        AnalysisResult = null;
        StateHasChanged();

        try
        {
            // 检查API Key
            if (string.IsNullOrEmpty(AppState.AIApiKey))
            {
                CurrentErrorMessage = "请先配置API Key";
                AnalysisResult = new AIService.AIAnalysisResult
                {
                    Success = false,
                    ErrorMessage = "请先在设置中配置AI API Key"
                };
            }
            else
            {
                // 调用AI分析
                AnalysisResult = await AIService.AnalyzeCrashLogAsync(logContent, additionalInfo);

                if (AnalysisResult.Success)
                {
                    await NotificationService.Success("日志分析完成", 3000);
                }
                else
                {
                    // 即使解析失败，也显示原始AI回复
                    if (!string.IsNullOrEmpty(AnalysisResult.Summary))
                    {
                        await NotificationService.Warning("AI回复解析部分成功，请查看原始内容", 5000);
                    }
                    else
                    {
                        await NotificationService.Error("分析失败: " + AnalysisResult.ErrorMessage, 5000);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            CurrentErrorMessage = $"分析过程中发生错误: {ex.Message}";
            AnalysisResult = new AIService.AIAnalysisResult
            {
                Success = false,
                ErrorMessage = ex.Message
            };
        }
        finally
        {
            IsAnalyzing = false;
            StateHasChanged();
        }
    }

    private void ClearInput()
    {
        logContent = "";
        additionalInfo = "";
        AnalysisResult = null;
        CurrentErrorMessage = "";
        StateHasChanged();
    }
}
