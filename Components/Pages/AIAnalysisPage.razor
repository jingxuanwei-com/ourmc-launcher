@* AI分析页面组件 *@
@using ourmclauncher.Models
@inject AIService AIService
@inject SettingsService SettingsService
@inject NotificationService NotificationService
@inject AppState AppState

@if (ShowWelcomeScreen)
{
    <div class="page-modal page-ai-welcome">
        <div class="modal-header">
            <div class="panel-title-bar">
                <span class="panel-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2L2 7l10 5 17-13 2 7-10 5z"/>
                        <path d="M12 2v20"/>
                        <circle cx="12" cy="12" r="3"/>
                    </svg>
                </span>
                <h2>AI日志分析助手</h2>
            </div>
        </div>
        <div class="modal-body ai-welcome-body">
            <div class="ai-welcome-content">
                <div class="ai-welcome-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                        <polyline points="7,10 12,15 17,10"/>
                        <line x1="12" y1="15" x2="12" y2="3"/>
                    </svg>
                </div>
                <h3>欢迎使用AI日志分析</h3>
                <p>这个功能可以帮助你快速分析游戏崩溃日志，找出问题原因并提供解决方案。</p>

                <div class="ai-welcome-features">
                    <div class="welcome-feature">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="16" x2="12" y2="12"/>
                            <line x1="12" y1="8" x2="12.01" y2="8"/>
                        </svg>
                        <div>
                            <h4>智能分析</h4>
                            <p>AI自动识别崩溃原因</p>
                        </div>
                    </div>
                    <div class="welcome-feature">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2h16zm16 8H4m8 0v8"/>
                        </svg>
                        <div>
                            <h4>解决方案</h4>
                            <p>提供具体修复步骤</p>
                        </div>
                    </div>
                    <div class="welcome-feature">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                            <polyline points="3.27,6.96 12,12.01 20.73,6.96"/>
                            <line x1="12" y1="22.08" x2="12" y2="12"/>
                        </svg>
                        <div>
                            <h4>模组识别</h4>
                            <p>检测相关模组冲突</p>
                        </div>
                    </div>
                </div>

                <div class="ai-welcome-actions">
                    <button class="btn-primary" @onclick="OpenConfigScreen">配置API Key开始使用</button>
                    <button class="btn-secondary" @onclick="SkipWelcome">稍后配置</button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="page-modal page-ai-analysis">
        <div class="modal-header">
            <div class="panel-title-bar">
                <span class="panel-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                        <polyline points="7,10 12,15 17,10"/>
                        <line x1="12" y1="15" x2="12" y2="3"/>
                    </svg>
                </span>
                <h2>AI日志分析</h2>
            </div>
            <div class="header-actions">
                <button class="btn-outline" @onclick="OpenConfigScreen" title="API设置">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M12 1v2m0 18v2M4.93 4.93l4.24 4.24m5.66 5.66l4.24 4.24"/>
                    </svg>
                    设置
                </button>
            </div>
        </div>
        <div class="modal-body ai-analysis-body">
            <div class="ai-input-section">
                <div class="section-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2h-2"/>
                        <line x1="18" y1="6" x2="18" y2="6"/>
                        <line x1="18" y1="10" x2="18" y2="10"/>
                        <line x1="18" y1="14" x2="18" y2="14"/>
                        <line x1="18" y1="18" x2="18" y2="18"/>
                    </svg>
                    <h3>提交崩溃日志</h3>
                </div>

                <div class="form-group">
                    <label>崩溃日志内容</label>
                    <textarea @bind="logContent" class="log-textarea" placeholder="粘贴游戏崩溃日志内容，包括错误信息、堆栈跟踪等..." rows="10"></textarea>
                    <div class="char-count">@logContent.Length 字符</div>
                </div>

                <div class="form-group">
                    <label>附加信息（可选）</label>
                    <input type="text" @bind="additionalInfo" placeholder="如：游戏版本、已安装的模组、发生崩溃时的操作..." />
                </div>

                <div class="analysis-actions">
                    <button class="btn-primary" @onclick="AnalyzeLog" disabled="@(string.IsNullOrEmpty(logContent) || IsAnalyzing)">
                        @if (IsAnalyzing)
                        {
                            <span class="loading-spinner"></span>
                            <span>分析中...</span>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                <polyline points="7,10 12,15 17,10"/>
                                <line x1="12" y1="15" x2="12" y2="3"/>
                            </svg>
                            <span>开始分析</span>
                        }
                    </button>
                    <button class="btn-outline" @onclick="ClearInput">清空</button>
                </div>

                @if (!string.IsNullOrEmpty(CurrentErrorMessage))
                {
                    <div class="error-message">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="16"/>
                        </svg>
                        @CurrentErrorMessage
                    </div>
                }
            </div>

            @if (AnalysisResult != null)
            {
                <div class="ai-result-section">
                    @if (!AnalysisResult.Success && string.IsNullOrEmpty(AnalysisResult.Summary))
                    {
                        <div class="result-error">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
                                <circle cx="12" cy="12" r="10"/>
                                <line x1="15" y1="9" x2="9" y2="15"/>
                                <line x1="9" y1="9" x2="15" y2="15"/>
                            </svg>
                            <h3>分析失败</h3>
                            <p>@AnalysisResult.ErrorMessage</p>
                        </div>
                    }
                    else if (!AnalysisResult.Success && !string.IsNullOrEmpty(AnalysisResult.Summary))
                    {
                        <div class="result-warning">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
                                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                                <line x1="12" y1="9" x2="12" y2="13"/>
                                <line x1="12" y1="17" x2="12.01" y2="17"/>
                            </svg>
                            <h3>解析部分失败</h3>
                            <p>AI回复格式不完全匹配预期，但这是原始回复：</p>
                            <div class="raw-content">
                                <pre>@AnalysisResult.Summary</pre>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="result-success">
                            <div class="result-header">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
                                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                                    <polyline points="22,4 12,14.01 9,11.01"/>
                                </svg>
                                <h3>分析完成</h3>
                            </div>

                            @if (!string.IsNullOrEmpty(AnalysisResult.CrashReason))
                            {
                                <div class="result-crash-reason">
                                    <div class="crash-reason-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M12 9v2m0 4a9 9 0 0 1 18 0a9 9 0 0 1-18 0z"/>
                                        <circle cx="12" cy="12" r="3"/>
                                        <line x1="12" y1="17" x2="12" y2="21"/>
                                    </svg>
                                    </div>
                                    <div class="crash-reason-content">
                                        <h4>崩溃原因</h4>
                                        <p>@AnalysisResult.CrashReason</p>
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(AnalysisResult.Summary))
                            {
                                <div class="result-summary">
                                    <h4>总结</h4>
                                    <p>@AnalysisResult.Summary</p>
                                </div>
                            }

                            @if (AnalysisResult.Suggestions.Count > 0)
                            {
                                <div class="result-suggestions">
                                    <h4>解决方案</h4>
                                    <ul class="suggestions-list">
                                        @foreach (var suggestion in AnalysisResult.Suggestions)
                                        {
                                            <li>@suggestion</li>
                                        }
                                    </ul>
                                </div>
                            }

                            @if (AnalysisResult.RelatedMods.Count > 0)
                            {
                                <div class="result-mods">
                                    <h4>可能相关的模组</h4>
                                    <div class="mods-tags">
                                        @foreach (var mod in AnalysisResult.RelatedMods)
                                        {
                                            <span class="mod-tag">@mod</span>
                                        }
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(AnalysisResult.TechnicalDetails))
                            {
                                <div class="result-technical">
                                    <details>
                                        <summary>技术详情</summary>
                                        <pre>@AnalysisResult.TechnicalDetails</pre>
                                    </details>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@* API配置弹窗 *@
@if (ShowConfigScreen)
{
    <div class="page-modal-overlay" @onclick="HideConfigScreen">
        <div class="config-dialog" @onclick:stopPropagation>
            <div class="modal-header">
                <div class="panel-title-bar">
                    <span class="panel-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="3"/>
                            <path d="M12 1v2m0 18v2"/>
                        </svg>
                    </span>
                    <h2>API设置</h2>
                </div>
                <button class="btn-icon" @onclick="HideConfigScreen">✕</button>
            </div>
            <div class="modal-body">
                <div class="config-info">
                    <p>配置AI服务的API Key以启用日志分析功能。支持OpenAI、Anthropic (Claude)、DeepSeek等服务。</p>
                </div>

                <div class="form-group">
                    <label>API Key</label>
                    <input type="password" @bind="tempApiKey" @bind:event="oninput" placeholder="输入你的API Key..." />
                    <small class="form-hint">API Key将加密保存在本地，不会上传到我们的服务器</small>
                </div>

                <div class="form-group">
                    <label>服务提供商</label>
                    <select @bind="tempProvider">
                        <option value="OpenAI">OpenAI</option>
                        <option value="Anthropic">Anthropic (Claude)</option>
                        <option value="DeepSeek">DeepSeek</option>
                    </select>
                    <small class="form-hint">日志将发送到 @AIService.GetProviderName(tempProvider)</small>
                </div>

                <div class="form-group">
                    <label>使用说明</label>
                    <div class="usage-guide">
                        <p><strong>支持的API Key格式：</strong></p>
                        <ul class="api-examples">
                            <li><code>sk-xxxxxxxxxxxxxxxxxxxxx</code> - OpenAI / DeepSeek</li>
                            <li><code>sk-ant-xxxxxxxxxxxxxxxxxxxxx</code> - Anthropic (Claude)</li>
                        </ul>
                        <p class="guide-link">
                            <a href="https://platform.openai.com/api-keys" target="_blank">获取OpenAI Key →</a>
                            <a href="https://console.anthropic.com/" target="_blank">获取Claude Key →</a>
                        </p>
                    </div>
                </div>

                <div class="config-actions">
                    <button class="btn-primary" @onclick="SaveApiKey" disabled="@(string.IsNullOrEmpty(tempApiKey))">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11a5 5 0 0 1 5 5v11a5 5 0 0 1-5 5z"/>
                            <polyline points="17,11 12,6 17,11 7,11 7,17"/>
                        </svg>
                        保存
                    </button>
                    <button class="btn-secondary" @onclick="HideConfigScreen">取消</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .ai-welcome-body {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 60px 40px;
    }

    .ai-welcome-content {
        text-align: center;
        max-width: 500px;
    }

    .ai-welcome-icon svg {
        width: 64px;
        height: 64px;
        color: #66BB6A;
        margin: 0 auto 20px;
    }

    .ai-welcome-content h3 {
        font-size: 1.5rem;
        margin-bottom: 12px;
        color: #e0e0e0;
    }

    .ai-welcome-content > p {
        color: rgba(255, 255, 255, 0.7);
        margin-bottom: 30px;
    }

    .ai-welcome-features {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .welcome-feature {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 20px;
        text-align: center;
    }

    .welcome-feature svg {
        width: 32px;
        height: 32px;
        color: #66BB6A;
        margin-bottom: 12px;
    }

    .welcome-feature h4 {
        font-size: 1rem;
        margin-bottom: 4px;
        color: #e0e0e0;
    }

    .welcome-feature p {
        font-size: 0.875rem;
        color: rgba(255, 255, 255, 0.6);
    }

    .ai-welcome-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
    }

    .ai-analysis-body {
        padding: 24px 36px;
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 24px;
    }

    .ai-input-section,
    .ai-result-section {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        padding: 24px;
    }

    .section-title {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .section-title svg {
        color: #66BB6A;
    }

    .section-title h3 {
        font-size: 1.25rem;
        margin: 0;
        color: #e0e0e0;
    }

    .log-textarea {
        width: 100%;
        min-height: 200px;
        padding: 16px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        color: #e0e0e0;
        font-family: 'Consolas', 'Monaco', monospace;
        font-size: 0.875rem;
        line-height: 1.6;
        resize: vertical;
    }

    .log-textarea:focus {
        outline: none;
        border-color: #66BB6A;
        box-shadow: 0 0 0 3px rgba(102, 187, 106, 0.1);
    }

    .char-count {
        text-align: right;
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.5);
        margin-top: 4px;
    }

    .analysis-actions {
        display: flex;
        gap: 12px;
        margin-top: 16px;
    }

    .loading-spinner {
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .error-message {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.3);
        border-radius: 12px;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        color: #f87171;
    }

    .result-success {
        background: rgba(102, 187, 106, 0.05);
        border: 1px solid rgba(102, 187, 106, 0.2);
        border-radius: 16px;
        padding: 24px;
    }

    .result-error {
        background: rgba(239, 68, 68, 0.05);
        border: 1px solid rgba(239, 68, 68, 0.2);
        border-radius: 16px;
        padding: 24px;
    }

    .result-warning {
        background: rgba(251, 191, 36, 0.05);
        border: 1px solid rgba(251, 191, 36, 0.2);
        border-radius: 16px;
        padding: 24px;
    }

    .raw-content {
        margin-top: 16px;
    }

    .raw-content pre {
        background: rgba(0, 0, 0, 0.3);
        border-radius: 8px;
        padding: 16px;
        white-space: pre-wrap;
        word-wrap: break-word;
        max-height: 400px;
        overflow-y: auto;
        font-family: 'Consolas', 'Monaco', monospace;
        font-size: 14px;
        line-height: 1.6;
        color: #e0e0e0;
    }

    .result-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        padding-bottom: 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .result-header svg {
        color: #66BB6A;
    }

    .result-header h3 {
        font-size: 1.25rem;
        margin: 0;
        color: #e0e0e0;
    }

    .result-crash-reason {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        border-radius: 12px;
        padding: 16px;
        display: flex;
        gap: 16px;
        margin-bottom: 16px;
    }

    .crash-reason-icon {
        flex-shrink: 0;
        width: 40px;
        height: 40px;
        background: rgba(239, 68, 68, 0.2);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .crash-reason-content h4 {
        margin: 0 0 8px 0;
        font-size: 1rem;
        color: #fca5a5;
    }

    .crash-reason-content p {
        margin: 0;
        color: rgba(255, 255, 255, 0.9);
    }

    .result-summary {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 16px;
    }

    .result-summary h4 {
        margin: 0 0 8px 0;
        font-size: 1rem;
        color: #e0e0e0;
    }

    .result-summary p {
        margin: 0;
        color: rgba(255, 255, 255, 0.8);
        line-height: 1.6;
    }

    .result-suggestions {
        margin-bottom: 16px;
    }

    .result-suggestions h4 {
        margin: 0 0 12px 0;
        font-size: 1rem;
        color: #e0e0e0;
    }

    .suggestions-list {
        margin: 0;
        padding-left: 20px;
        color: rgba(255, 255, 255, 0.8);
        line-height: 1.8;
    }

    .suggestions-list li {
        margin-bottom: 8px;
    }

    .result-mods {
        margin-bottom: 16px;
    }

    .result-mods h4 {
        margin: 0 0 12px 0;
        font-size: 1rem;
        color: #e0e0e0;
    }

    .mods-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .mod-tag {
        background: rgba(33, 150, 243, 0.15);
        border: 1px solid rgba(33, 150, 243, 0.3);
        color: #64B5F6;
        padding: 4px 12px;
        border-radius: 6px;
        font-size: 0.875rem;
    }

    .result-technical {
        margin-top: 16px;
    }

    .result-technical summary {
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        padding: 12px;
        margin-top: 8px;
    }

    .result-technical pre {
        margin: 0;
        white-space: pre-wrap;
        word-wrap: break-word;
        font-family: 'Consolas', 'Monaco', monospace;
        font-size: 0.875rem;
        color: rgba(255, 255, 255, 0.7);
    }

    .config-dialog {
        background: rgba(20, 20, 35, 0.95);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        width: 90%;
        max-width: 520px;
        max-height: 90vh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
    }

    .config-info {
        background: rgba(102, 187, 106, 0.1);
        border: 1px solid rgba(102, 187, 106, 0.2);
        border-radius: 12px;
        padding: 12px 16px;
        margin-bottom: 24px;
        color: rgba(255, 255, 255, 0.9);
    }

    .provider-info {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 16px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        margin-top: 8px;
    }

    .provider-badge {
        display: flex;
        align-items: center;
        gap: 6px;
        color: #66BB6A;
        font-weight: 500;
    }

    .provider-placeholder {
        color: rgba(255, 255, 255, 0.5);
    }

