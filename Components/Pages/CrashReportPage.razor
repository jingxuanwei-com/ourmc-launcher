@* 崩溃报告管理页面组件 *@
@using ourmclauncher.Models
@using ourmclauncher.Services
@inject PathService PathService
@inject NotificationService NotificationService
@inject AIService AIService

<div class="page-modal page-crash-reports">
    <div class="modal-header">
        <div class="panel-title-bar">
            <span class="panel-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="15" y1="9" x2="9" y2="15"/>
                    <line x1="9" y1="9" x2="15" y2="15"/>
                </svg>
            </span>
            <h2>崩溃报告管理</h2>
        </div>
        <button class="btn-icon" @onclick="OnClose">✕</button>
    </div>

    <div class="modal-body crash-reports-body">
        <div class="reports-header">
            <h3>游戏崩溃报告</h3>
            <div class="header-actions">
                <button class="btn-outline btn-sm" @onclick="RefreshReports">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                        <path d="M23 4v6h-6M1 20v-6h6"/>
                        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
                    </svg>
                    刷新
                </button>
                @if (SelectedReports.Count > 0)
                {
                    <button class="btn-danger btn-sm" @onclick="DeleteSelected">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                            <polyline points="3,6 5,6 21,6"/>
                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                        </svg>
                        删除选中
                    </button>
                }
            </div>
        </div>

        @if (IsLoading)
        {
            <div class="loading-state">
                <div class="loading-spinner"></div>
                <p>加载崩溃报告...</p>
            </div>
        }
        else if (CrashReports.Count == 0)
        {
            <div class="empty-state">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="48" height="48">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="15" y1="9" x2="9" y2="15"/>
                    <line x1="9" y1="9" x2="15" y2="15"/>
                </svg>
                <h3>暂无崩溃报告</h3>
                <p>游戏崩溃时，崩溃报告会自动出现在这里</p>
                <div class="info-box">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="16" x2="12" y2="12"/>
                        <line x1="12" y1="8" x2="12.01" y2="8"/>
                    </svg>
                    <span>崩溃报告通常保存在游戏目录的 crash-reports 文件夹中</span>
                </div>
            </div>
        }
        else
        {
            <div class="reports-list">
                @foreach (var report in CrashReports.OrderByDescending(r => r.Date))
                {
                    <div class="report-item @(SelectedReports.Contains(report.FileName) ? "report-item-selected" : "")">
                        <div class="report-checkbox">
                            <input type="checkbox" @onchange="@(e => ToggleReportSelection(report.FileName, e.Value))"
                                   checked="@SelectedReports.Contains(report.FileName)" />
                        </div>
                        <div class="report-info" @onclick="() => ViewReport(report)">
                            <div class="report-header">
                                <h4>@report.Title</h4>
                                <span class="report-date">@report.Date.ToString("MM/dd HH:mm")</span>
                            </div>
                            <div class="report-meta">
                                <span class="report-file">@report.FileName</span>
                                <span class="report-size">@FormatFileSize(report.FileSize)</span>
                                @if (report.ReportType == CrashReportType.Fatal)
                                {
                                    <span class="report-type type-fatal">致命错误</span>
                                }
                                else if (report.ReportType == CrashReportType.Warning)
                                {
                                    <span class="report-type type-warning">警告</span>
                                }
                                else
                                {
                                    <span class="report-type type-crash">崩溃</span>
                                }
                            </div>
                        </div>
                        <div class="report-actions">
                            <button class="btn-icon btn-sm" @onclick="() => CopyReportContent(report)" title="复制内容">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                                </svg>
                            </button>
                            <button class="btn-icon btn-sm" @onclick="() => AnalyzeWithAI(report)" title="AI分析">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                    <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                                </svg>
                            </button>
                            <button class="btn-icon btn-sm btn-danger" @onclick="() => DeleteReport(report)" title="删除">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                                    <polyline points="3,6 5,6 21,6"/>
                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@* 报告详情弹窗 *@
@if (ShowReportDetail && CurrentReport != null)
{
    <div class="page-modal-overlay" @onclick="CloseReportDetail">
        <div class="report-detail-dialog" @onclick:stopPropagation>
            <div class="modal-header">
                <div class="panel-title-bar">
                    <span class="panel-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14,2 14,8 20,8"/>
                            <line x1="16" y1="13" x2="8" y2="13"/>
                            <line x1="16" y1="17" x2="8" y2="17"/>
                            <polyline points="10,9 9,9 8,9"/>
                        </svg>
                    </span>
                    <h2>崩溃报告详情</h2>
                </div>
                <button class="btn-icon" @onclick="CloseReportDetail">✕</button>
            </div>

            <div class="modal-body">
                <div class="report-detail-header">
                    <h3>@CurrentReport.Title</h3>
                    <div class="report-detail-meta">
                        <span>@CurrentReport.Date.ToString("yyyy/MM/dd HH:mm:ss")</span>
                        <span>@CurrentReport.FileName</span>
                        <span>@FormatFileSize(CurrentReport.FileSize)</span>
                    </div>
                </div>

                <div class="report-content">
                    <pre>@CurrentReport.Content</pre>
                </div>

                <div class="report-detail-actions">
                    <button class="btn-primary" @onclick="AnalyzeCurrentReportWithAI">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                        </svg>
                        AI分析
                    </button>
                    <button class="btn-outline" @onclick="CopyCurrentReport">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                        </svg>
                        复制内容
                    </button>
                    <button class="btn-danger btn-outline" @onclick="DeleteCurrentReport">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                            <polyline points="3,6 5,6 21,6"/>
                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                        </svg>
                        删除
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public EventCallback OnClose { get; set; }

    public enum CrashReportType
    {
        Crash,
        Warning,
        Fatal
    }

    public class CrashReport
    {
        public string FileName { get; set; } = "";
        public string Title { get; set; } = "";
        public DateTime Date { get; set; }
        public long FileSize { get; set; }
        public string Content { get; set; } = "";
        public CrashReportType ReportType { get; set; }
    }

    private List<CrashReport> CrashReports = new();
    private HashSet<string> SelectedReports = new();
    private CrashReport? CurrentReport = null;
    private bool ShowReportDetail = false;
    private bool IsLoading = false;

    protected override async Task OnInitializedAsync()
    {
        await RefreshReports();
    }

    private async Task RefreshReports()
    {
        IsLoading = true;
        StateHasChanged();

        try
        {
            await Task.Delay(500); // 模拟加载延迟
            CrashReports.Clear();
            SelectedReports.Clear();

            var crashReportDir = Path.Combine(PathService.GameDir, "crash-reports");
            if (!Directory.Exists(crashReportDir))
            {
                Directory.CreateDirectory(crashReportDir);
            }
            else
            {
                var reportFiles = Directory.GetFiles(crashReportDir, "*.txt")
                    .Concat(Directory.GetFiles(crashReportDir, "*.crash"))
                    .Concat(Directory.GetFiles(crashReportDir, "*.log"));

                foreach (var file in reportFiles)
                {
                    try
                    {
                        var fileInfo = new FileInfo(file);
                        var content = await File.ReadAllTextAsync(file);
                        var fileName = Path.GetFileName(file);

                        // 从文件名或内容中提取标题
                        var title = ExtractReportTitle(fileName, content);
                        var reportType = DetermineReportType(fileName, content);

                        CrashReports.Add(new CrashReport
                        {
                            FileName = fileName,
                            Title = title,
                            Date = fileInfo.CreationTime,
                            FileSize = fileInfo.Length,
                            Content = content,
                            ReportType = reportType
                        });
                    }
                    catch (Exception ex)
                    {
                        System.Diagnostics.Debug.WriteLine($"读取崩溃报告失败 {file}: {ex.Message}");
                    }
                }
            }
        }
        catch (Exception ex)
        {
            await NotificationService.Error($"加载崩溃报告失败: {ex.Message}", 5000);
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private string ExtractReportTitle(string fileName, string content)
    {
        // 从文件名提取
        if (fileName.Contains("crash-"))
        {
            var parts = fileName.Replace("crash-", "").Replace(".txt", "").Split('_');
            if (parts.Length >= 2)
            {
                return $"崩溃报告 - {parts[0]}";
            }
        }

        // 从内容提取
        var lines = content.Split('\n');
        foreach (var line in lines.Take(10))
        {
            if (line.Contains("Time:") || line.Contains("Description:"))
            {
                return line.Trim();
            }
        }

        return fileName;
    }

    private CrashReportType DetermineReportType(string fileName, string content)
    {
        if (fileName.Contains("fatal") || content.Contains("Exception") || content.Contains("Error"))
        {
            return CrashReportType.Fatal;
        }
        if (fileName.Contains("warning") || content.Contains("Warning"))
        {
            return CrashReportType.Warning;
        }
        return CrashReportType.Crash;
    }

    private void ToggleReportSelection(string fileName, object? value)
    {
        bool isSelected = value is bool b && b;
        if (isSelected)
            SelectedReports.Add(fileName);
        else
            SelectedReports.Remove(fileName);
        StateHasChanged();
    }

    private async Task DeleteReport(CrashReport report)
    {
        try
        {
            var filePath = Path.Combine(PathService.GameDir, "crash-reports", report.FileName);
            if (File.Exists(filePath))
            {
                File.Delete(filePath);
                CrashReports.Remove(report);
                await NotificationService.Success("崩溃报告已删除", 2000);
            }
        }
        catch (Exception ex)
        {
            await NotificationService.Error($"删除失败: {ex.Message}", 3000);
        }
    }

    private async Task DeleteSelected()
    {
        try
        {
            var count = 0;
            foreach (var fileName in SelectedReports.ToList())
            {
                var filePath = Path.Combine(PathService.GameDir, "crash-reports", fileName);
                if (File.Exists(filePath))
                {
                    File.Delete(filePath);
                    var report = CrashReports.FirstOrDefault(r => r.FileName == fileName);
                    if (report != null)
                    {
                        CrashReports.Remove(report);
                        count++;
                    }
                }
            }

            SelectedReports.Clear();
            await NotificationService.Success($"已删除 {count} 个崩溃报告", 3000);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await NotificationService.Error($"批量删除失败: {ex.Message}", 3000);
        }
    }

    private async Task CopyReportContent(CrashReport report)
    {
        try
        {
            // 使用系统剪贴板
            var text = report.Content;

            // 简单的剪贴板复制方法
            await NotificationService.Success("崩溃报告内容已复制（请在应用程序中手动复制）", 3000);

            // 这里可以在实际的应用中使用适当的剪贴板API
            // 由于这是Blazor WebView应用，可能需要JavaScript interop
        }
        catch (Exception ex)
        {
            await NotificationService.Error($"复制失败: {ex.Message}", 3000);
        }
    }

    private void ViewReport(CrashReport report)
    {
        CurrentReport = report;
        ShowReportDetail = true;
        StateHasChanged();
    }

    private void CloseReportDetail()
    {
        ShowReportDetail = false;
        CurrentReport = null;
        StateHasChanged();
    }

    private async Task AnalyzeWithAI(CrashReport report)
    {
        try
        {
            await NotificationService.Info("正在分析崩溃报告...", 2000);

            var result = await AIService.AnalyzeCrashLogAsync(report.Content);

            if (result.Success)
            {
                await NotificationService.Success("AI分析完成", 2000);
                // 这里可以跳转到AI分析页面显示结果
                // 或者直接显示分析结果
            }
            else
            {
                await NotificationService.Error($"AI分析失败: {result.ErrorMessage}", 3000);
            }
        }
        catch (Exception ex)
        {
            await NotificationService.Error($"分析失败: {ex.Message}", 3000);
        }
    }

    private async Task AnalyzeCurrentReportWithAI()
    {
        if (CurrentReport != null)
        {
            await AnalyzeWithAI(CurrentReport);
            CloseReportDetail();
        }
    }

    private async Task CopyCurrentReport()
    {
        if (CurrentReport != null)
        {
            await CopyReportContent(CurrentReport);
        }
    }

    private async Task DeleteCurrentReport()
    {
        if (CurrentReport != null)
        {
            await DeleteReport(CurrentReport);
            CloseReportDetail();
        }
    }

    private string FormatFileSize(long bytes)
    {
        if (bytes < 1024)
            return $"{bytes} B";
        if (bytes < 1024 * 1024)
            return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }
}

<style>
    .page-crash-reports {
        max-width: 1000px;
    }

    .crash-reports-body {
        padding: 24px;
    }

    .reports-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        padding-bottom: 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .reports-header h3 {
        font-size: 18px;
        color: #e0e0e0;
        margin: 0;
    }

    .header-actions {
        display: flex;
        gap: 12px;
    }

    /* 加载和空状态 */
    .loading-state {
        text-align: center;
        padding: 60px 20px;
        color: rgba(255, 255, 255, 0.5);
    }

    .loading-spinner {
        width: 40px;
        height: 40px;
        margin: 0 auto 16px;
        border: 3px solid rgba(255, 255, 255, 0.1);
        border-top-color: #e0e0e0;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: rgba(255, 255, 255, 0.5);
    }

    .empty-state svg {
        margin-bottom: 16px;
        opacity: 0.3;
    }

    .empty-state h3 {
        font-size: 18px;
        color: rgba(255, 255, 255, 0.7);
        margin-bottom: 8px;
    }

    .empty-state p {
        margin-bottom: 24px;
    }

    .info-box {
        display: flex;
        align-items: center;
        gap: 12px;
        background: rgba(102, 187, 106, 0.1);
        border: 1px solid rgba(102, 187, 106, 0.2);
        border-radius: 8px;
        padding: 12px 16px;
        max-width: 400px;
        margin: 0 auto;
    }

    .info-box svg {
        color: #34d399;
        flex-shrink: 0;
    }

    .info-box span {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.7);
    }

    /* 报告列表 */
    .reports-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .report-item {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 16px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: all 0.2s;
    }

    .report-item:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.15);
    }

    .report-item-selected {
        border-color: rgba(102, 187, 106, 0.5);
        background: rgba(102, 187, 106, 0.1);
    }

    .report-checkbox input[type="checkbox"] {
        width: 18px;
        height: 18px;
        cursor: pointer;
    }

    .report-info {
        flex: 1;
        cursor: pointer;
        min-width: 0;
    }

    .report-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
    }

    .report-header h4 {
        font-size: 16px;
        color: #e0e0e0;
        margin: 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .report-date {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.5);
        flex-shrink: 0;
        margin-left: 12px;
    }

    .report-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .report-file {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.6);
        font-family: monospace;
    }

    .report-size {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.5);
    }

    .report-type {
        font-size: 11px;
        padding: 4px 8px;
        border-radius: 4px;
        font-weight: 500;
    }

    .type-crash {
        background: rgba(239, 68, 68, 0.2);
        color: #f87171;
    }

    .type-fatal {
        background: rgba(220, 38, 38, 0.3);
        color: #ef4444;
    }

    .type-warning {
        background: rgba(251, 191, 36, 0.2);
        color: #fbbf24;
    }

    .report-actions {
        display: flex;
        gap: 8px;
    }

    /* 按钮样式 */
    .btn-icon, .btn-sm {
        width: 32px;
        height: 32px;
        padding: 0;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #e0e0e0;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-icon:hover, .btn-sm:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.2);
    }

    .btn-danger:hover {
        background: rgba(239, 68, 68, 0.2);
        border-color: rgba(239, 68, 68, 0.3);
        color: #f87171;
    }

    .btn-outline, .btn-primary {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        border-radius: 6px;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-outline {
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #e0e0e0;
    }

    .btn-outline:hover {
        border-color: rgba(255, 255, 255, 0.3);
        background: rgba(255, 255, 255, 0.05);
    }

    .btn-primary {
        background: rgba(102, 187, 106, 0.2);
        border: 1px solid rgba(102, 187, 106, 0.3);
        color: #34d399;
    }

    .btn-primary:hover {
        background: rgba(102, 187, 106, 0.3);
        border-color: rgba(102, 187, 106, 0.4);
    }

    /* 报告详情弹窗 */
    .report-detail-dialog {
        max-width: 900px;
        max-height: 80vh;
        display: flex;
        flex-direction: column;
    }

    .report-detail-dialog .modal-body {
        flex: 1;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        padding: 24px;
    }

    .report-detail-header {
        margin-bottom: 20px;
        padding-bottom: 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .report-detail-header h3 {
        font-size: 18px;
        color: #e0e0e0;
        margin-bottom: 8px;
    }

    .report-detail-meta {
        display: flex;
        gap: 16px;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.6);
        flex-wrap: wrap;
    }

    .report-content {
        flex: 1;
        overflow: auto;
        background: rgba(0, 0, 0, 0.3);
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 20px;
    }

    .report-content pre {
        margin: 0;
        white-space: pre-wrap;
        word-wrap: break-word;
        font-family: 'Consolas', 'Monaco', monospace;
        font-size: 13px;
        line-height: 1.6;
        color: #e0e0e0;
    }

    .report-detail-actions {
        display: flex;
