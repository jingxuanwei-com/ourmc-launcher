@* 设置页面组件 *@
<div class="page-modal page-settings @(IsClosing ? "closing" : "")">
    <div class="modal-header">
        <div class="panel-title-bar">
            <span class="panel-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
                </svg>
            </span>
            <h2>设置</h2>
        </div>
    </div>
    <div class="modal-body">
        <div class="settings-group">
            <h3>Java 设置</h3>
            <div class="form-group">
                <label>Java 路径</label>
                <div class="input-row">
                    <input type="text" class="input-flex" @bind="JavaPath" @bind:event="oninput" placeholder="javaw.exe 的完整路径" />
                    <button class="btn-outline btn-sm" @onclick="OnAutoDetectJava">自动检测</button>
                </div>
            </div>
            <div class="form-group">
                <label>最大内存 (MB)</label>
                <input type="number" @bind="MaxMemory" @bind:event="oninput" min="512" max="32768" step="256" />
            </div>
        </div>
        <div class="settings-group">
            <h3>游戏设置</h3>
            <div class="form-group">
                <label>游戏目录</label>
                <input type="text" @bind="GameDirectory" @bind:event="oninput" placeholder=".minecraft 目录路径" />
            </div>
            <div class="form-group">
                <label>玩家名称（离线模式）</label>
                <input type="text" @bind="PlayerName" @bind:event="oninput" placeholder="Player" />
            </div>
        </div>
        <div class="settings-actions">
            <button class="btn-primary" @onclick="OnSaveSettings">保存设置</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public string JavaPath { get; set; } = "";
    [Parameter] public int MaxMemory { get; set; } = 2048;
    [Parameter] public string GameDirectory { get; set; } = "";
    [Parameter] public string PlayerName { get; set; } = "Player";
    [Parameter] public bool IsClosing { get; set; }
    [Parameter] public EventCallback OnAutoDetectJava { get; set; }
    [Parameter] public EventCallback OnSaveSettings { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
}
